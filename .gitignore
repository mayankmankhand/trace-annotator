# Dependencies
node_modules/

# Environment (API keys)
.env*.local
.env

# OS
.DS_Store

# Debug logs
npm-debug.log*

# Editor
.idea/
.vscode/
*.swp

# Temporary files
/tmp/
/_tmp/

# Plan files (local working docs, stored in plans/)
plans/PLAN-*.md

# IDE (local Cursor settings - shared commands are in .claude/commands/)
.cursor/

# Claude Code worktrees (Remote Control spawn mode)
.claude/worktrees/

# Project index (auto-generated by toolkit)
INDEX.md

# Toolkit backups (originals preserved by setup.sh before overwrite/delete)
.toolkit-backup-*/

# Next.js build output (added once skeleton lands)
.next/
next-env.d.ts
*.tsbuildinfo

# User trace data (BYO, never committed)
/data/
/traces/

# Label output (written by the app, never committed)
/labels/
