# Copy to .env.local and fill in your API key.
# Never commit .env.local.
# Quotes around values are optional - the parser handles both formats.
# Don't include 'export' - this is a .env file, not a shell script.

# Required for /ask-gpt command (ChatGPT API calls)
OPENAI_API_KEY=

# Model version for ChatGPT (default: gpt-5.5)
# GPT_MODEL=gpt-5.5

# Required for /ask-gemini command (Gemini API calls)
GEMINI_API_KEY=

# Model version for Gemini (default: gemini-3.1-pro-preview)
# GEMINI_MODEL=gemini-3.1-pro-preview

# Fallback mode: set to "1" to use concatenated prompts instead of systemInstruction
# Use this if you encounter issues with systemInstruction on your model/SDK version
# GEMINI_USE_CONCAT_PROMPT=1
